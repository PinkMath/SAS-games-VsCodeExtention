{
  "name": "sas",
  "displayName": "SAS",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sas.Snake",
        "title": "Snake Game 🐍"
      },
      {
        "command": "sas.tic-tac-toe",
        "title": "Tic-tac-toe ❌🔴"
      }
    ],
    "keybindings":[
      {
        "command": "sas.Snake",
        "key": "ctrl+shift+s",
        "when": "editorTextFocus"
      },
      {
        "command": "sas.tic-tac-toe",
        "key": "ctrl+shift+t",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
